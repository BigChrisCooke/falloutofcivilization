# Local dev ports
BACKEND_PORT=6201
PORT=6201
CLIENT_PORT=6200

# Browser-safe runtime config
VITE_API_BASE_URL=http://localhost:6201
VITE_APP_RELEASE=dev

# Backend runtime and static asset paths
CLIENT_ORIGIN=http://localhost:6200
CLIENT_DIST_PATH=../client/dist
GAME_CONTENT_ROOT=

# Database driver config
DB_DRIVER=sqlite
SQLITE_PATH=./data/app.db
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=falloutofcivilization
POSTGRES_SSL=false
DB_POOL_MAX=10

# Session and proxy behavior
COOKIE_SECURE=false
TRUST_PROXY=false
SESSION_TTL_DAYS=14
