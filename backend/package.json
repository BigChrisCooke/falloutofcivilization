{
  "name": "@fallout/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "test": "vitest run --coverage",
    "test:postgres": "node -e \"if (!process.env.TEST_DATABASE_URL) { throw new Error('TEST_DATABASE_URL is required for npm run test:postgres'); }\" && vitest run src/__tests__/postgres_smoke.test.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.8.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.11",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.0.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  }
}
